{
  "name": "awscostbot",
  "version": "1.0.0",
  "description": "Provides visibility on AWS costs",
  "main": "index.js",
  "scripts": {
    "start": "node bin/start.js",
    "cdk": "cdk",
    "bootstrap": "cdk bootstrap",
    "deploy": "node --run check && cdk deploy",
    "check": "npm ci --no-audit --no-fund && npx run-s \"check:**\"",
    "check:types": "tsc --noEmit",
    "check:cdk": "cross-env CONFIG_FILE=arn:aws:s3:::bucket/key cdk synth"
  },
  "keywords": [
    "aws"
  ],
  "author": "neisha",
  "license": "None",
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "3.988.0",
    "@aws-sdk/client-s3": "3.988.0",
    "@slack/web-api": "6.10.0",
    "aws-cdk-lib": "2.260.0",
    "axios": "1.18.1",
    "constructs": "10.6.0",
    "moment": "2.29.4"
  },
  "devDependencies": {
    "@types/node": "24.10.2",
    "aws-cdk": "2.1126.0",
    "cross-env": "10.1.0",
    "esbuild": "0.28.1",
    "npm-run-all2": "8.0.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24"
  }
}
